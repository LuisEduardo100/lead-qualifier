# ── LLM (obrigatório) ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Evolution API (obrigatório) ────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=your-evolution-api-key

# ── URL pública da API (opcional — uso futuro para links externos) ─────────────
# Atualmente não usada pelo backend; reservada para integrações externas.
PUBLIC_URL=https://api.seudominio.com

# ── URL interna da API (alvo dos webhooks da Evolution) ────────────────────────
# A Evolution API roda na rede docker `lq_internal` (sem saída para internet),
# então o webhook precisa apontar para o nome do serviço docker, não o domínio.
INTERNAL_API_URL=http://api:8000

# ── Autenticação do painel ─────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── E-mail para follow-ups (opcional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=Consultor Comercial

# ── Banco de dados (opcional — padrão SQLite) ──────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/leads.db
