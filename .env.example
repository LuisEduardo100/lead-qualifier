# ── LLM (obrigatório) ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Evolution API (obrigatório) ────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=your-evolution-api-key

# ── URL pública da API (obrigatório em produção) ───────────────────────────────
# Usada para registrar o webhook nas instâncias da Evolution API.
# Em Docker Compose interno: http://api:8000
# Em produção com domínio real: https://api.seudominio.com
PUBLIC_URL=http://api:8000

# ── Autenticação do painel ─────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── E-mail para follow-ups (opcional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=Consultor Comercial

# ── Banco de dados (opcional — padrão SQLite) ──────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/leads.db
